# ============================================
# API Gateway de Esportes - Exemplo de Variáveis
# Copie para .env e preencha com seus valores
# ============================================

# BANCO DE DADOS
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# RapidAPI Flashscore4
RAPIDAPI_KEY=""

# AUTENTICAÇÃO (JWT_SECRET é obrigatório - o app não inicia sem ele)
JWT_SECRET=""
GOOGLE_CLIENT_ID="your_google_client_id_here"

# CACHE (TTL em segundos)
CACHE_TTL_FIXTURES=3600
CACHE_TTL_STANDINGS=86400
CACHE_TTL_STATISTICS=7200
CACHE_TTL_LINEUPS=1800

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_IP=100

# AMBIENTE
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
